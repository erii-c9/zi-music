{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zi Music",
  "version": "0.1.1",
  "identifier": "com.zimusic.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Zi Music",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "targets": "nsis",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
